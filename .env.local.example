# Server-side AI provider key (never expose to the browser)
OPENAI_API_KEY=TODO_SET_LOCALLY_OPENAI_API_KEY

# Optional model override for server endpoint
OPENAI_MODEL=gpt-4o-mini

# Web Search Connector provider selector (client-safe)
# Supported values: tavily, serpapi
VITE_WEB_SEARCH_PROVIDER=tavily

# Server-side web search provider API key (never expose to the browser)
WEB_SEARCH_API_KEY=TODO_SET_LOCALLY_WEB_SEARCH_API_KEY

# Supabase client configuration for browser auth flows
# These values are public-safe (anon key + project URL).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Note:
# Do not put provider secrets in VITE_* variables.
# VITE_* variables are exposed to client-side code.
