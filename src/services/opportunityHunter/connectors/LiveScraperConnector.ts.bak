/**
 * LiveScraperConnector
 *
 * Fetches rental apartment listings directly from public portal pages.
 * Supported portals: 4zida.rs, halooglasi.com
 *
 * Constraints:
 * - Public pages only (no login, no CAPTCHA bypass)
 * - Minimum 5 seconds between requests per domain
 * - Maximum 3 pages per source per run
 * - Graceful error handling — never crashes the Hunter
 */

import type { OpportunityConnector, ConnectorInput } from '../types'
import type { RawOpportunity } from '@/lib/types/opportunityHunter'
import * as cheerio from 'cheerio'

// ── Types ─────────────────────────────────────────────────────────

type PortalKey = '4zida' | 'halooglasi'

type LiveScraperConfig = {
  portal: PortalKey
  city: string
  districts: string[]
  maxPages: number
  baseUrlOverride: string | null
}

type ScrapedListing = {
  title: string
  sourceUrl: string
  price: number | null
  currency: string | null
  sizeM2: number | null
  bedrooms: number | null
  district: string | null
  city: string | null
  imageUrl: string | null
  floor: number | null
  furnished: boolean | null
}

// ── Helpers ───────────────────────────────────────────────────────

const toArray = (value: unknown): string[] => {
  if (!Array.isArray(value)) return []
  return value
    .filter((item): item is string => typeof item === 'string')
    .map((item) => item.trim())
    .filter(Boolean)
}

const parseConfig = (input: ConnectorInput): LiveScraperConfig => {
  const config = input.source.connector_config && typeof input.source.connector_config === 'object'
    ? input.source.connector_config as Record<string, unknown>
    : {}

  const portalRaw = typeof config.portal === 'string' ? config.portal.toLowerCase().trim() : ''
  const portal: PortalKey = portalRaw === 'halooglasi' || portalRaw === 'halo oglasi' ? 'halooglasi' : '4zida'

  return {
    portal,
    city: typeof config.city === 'string' && config.city.trim() ? config.city.trim() : (input.brief.cities[0] ?? 'Novi Sad'),
    districts: toArray(config.districts),
    maxPages: Number.isFinite(Number(config.maxPages)) && Number(config.maxPages) > 0
      ? Math.min(Math.round(Number(config.maxPages)), 3)
      : 3,
    baseUrlOverride: typeof config.baseUrlOverride === 'string' && config.baseUrlOverride.trim()
      ? config.baseUrlOverride.trim()
      : null,
  }
}

const sleep = (ms: number): Promise<void> => new Promise((resolve) => setTimeout(resolve, ms))

const parseNumeric = (value: string | null | undefined): number | null => {
  if (!value) return null
  const cleaned = value.replace(/\s/g, '').replace(/\./g, '').replace(',', '.')
  const parsed = Number(cleaned)
  return Number.isFinite(parsed) ? parsed : null
}

const stripHtml = (value: string): string => value
  .replace(/<script[\s\S]*?<\/script>/gi, ' ')
  .replace(/<style[\s\S]*?<\/style>/gi, ' ')
  .replace(/<[^>]+>/g, ' ')
  .replace(/&nbsp;/gi, ' ')
  .replace(/&/gi, '&')
  .replace(/&#\d+;/g, ' ')
  .replace(/\s+/g, ' ')
  .trim()

const inferBedrooms = (text: string): number | null => {
  const lower = text.toLowerCase()
  const map: Record<string, number> = {
    'jednosoban': 1, 'jednoiposoban': 1.5,
    'dvosoban': 2, 'dvoiposoban': 2.5,
    'trosoban': 3, 'troiposoban': 3.5,
    'četvorosoban': 4, 'cetvorosoban': 4,
    'petosoban': 5,
  }
  for (const [keyword, count] of Object.entries(map)) {
    if (lower.includes(keyword)) return count
  }
  const match = lower.match(/(\d)\s?(?:sob|stan|room|bed)/i)
  if (match) {
    const num = Number(match[1])
    if (Number.isFinite(num) && num >= 0 && num <= 10) return num
  }
  return null
}

const NOVI_SAD_DISTRICTS = [
  'liman 1', 'liman 2', 'liman 3', 'liman 4', 'liman',
  'grbavica', 'podbara', 'detelinara', 'novo naselje',
  'stari grad', 'sremska kamenica', 'petrovaradin',
  'telep', 'adice', 'satelit', 'bistrica',
  'sajmište', 'sajmiste', 'bulevar', 'rotkvarija',
  'adamovićevo naselje', 'adamovicevo naselje',
]

const inferDistrict = (text: string): string | null => {
  const lower = text.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '')
  for (const d of NOVI_SAD_DISTRICTS) {
    const normalized = d.normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    if (lower.includes(normalized)) {
      return d.charAt(0).toUpperCase() + d.slice(1)
    }
  }
  return null
}

// ── Rate-limited fetcher ──────────────────────────────────────────

const lastRequestTime: Record<string, number> = {}

const rateLimitedFetch = async (url: string, minDelayMs = 5000): Promise<string> => {
  let hostname: string
  try {
    hostname = new URL(url).hostname
  } catch {
    throw new Error(`Invalid URL: ${url}`)
  }

  const lastTime = lastRequestTime[hostname] ?? 0
  const elapsed = Date.now() - lastTime
  if (elapsed < minDelayMs) {
    await sleep(minDelayMs - elapsed)
  }

  lastRequestTime[hostname] = Date.now()

  const response = await fetch(url, {
    headers: {
      'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
      'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
      'Accept-Language': 'sr-RS,sr;q=0.9,en;q=0.8',
    },
    redirect: 'follow',
    signal: AbortSignal.timeout(15000),
  })

  if (!response.ok) {
    throw new Error(`HTTP ${response.status} for ${url}`)
  }

  return response.text()
}

// ── 4zida.rs Scraper ─────────────────────────────────────────────

const build4zidaUrls = (config: LiveScraperConfig): string[] => {
  const citySlug = config.city.toLowerCase().replace(/\s+/g, '-')
  const urls: string[] = []

  // Main search page
  if (config.baseUrlOverride) {
    urls.push(config.baseUrlOverride)
  } else {
    urls.push(`https://4zida.rs/izdavanje-stanova/${citySlug}`)
  }

  // Additional pages
  for (let page = 2; page <= config.maxPages; page++) {
    const baseUrl = config.baseUrlOverride ?? `https://4zida.rs/izdavanje-stanova/${citySlug}`
    urls.push(`${baseUrl}?page=${page}`)
  }

  return urls
}

const parse4zidaListings = (html: string, pageUrl: string): ScrapedListing[] => {
  const $ = cheerio.load(html)
  const listings: ScrapedListing[] = []

  // ── Strategy 1: JSON-LD ItemList (most reliable) ─────────────
  $('script[type="application/ld+json"]').each((_, el) => {
    const content = $(el).html() ?? ''
    try {
      const data = JSON.parse(content)
      const items = data['@type'] === 'ItemList' ? data.itemListElement : null
      if (!Array.isArray(items)) return

      for (const item of items) {
        const listing = item?.item ?? item
        if (!listing || listing['@type'] !== 'RealEstateListing') continue

        const name = typeof listing.name === 'string' ? listing.name : ''
        const listingUrl = typeof listing.url === 'string' ? listing.url : ''
        const price = typeof listing.offers?.price === 'number' ? listing.offers.price : null
        const currency = typeof listing.offers?.priceCurrency === 'string' ? listing.offers.priceCurrency : null
        const sizeM2 = typeof listing.itemOffered?.floorSize?.value === 'number' ? listing.itemOffered.floorSize.value : null
        const rooms = typeof listing.itemOffered?.numberOfRooms === 'number' ? listing.itemOffered.numberOfRooms : null
        const imageUrl = typeof listing.image?.url === 'string' ? listing.image.url : null

        // Extract district from URL path (e.g., /izdavanje-stanova/novi-sad-liman-...)
        const districtFromUrl = listingUrl.match(/izdavanje-stanova\/novi-sad[- ]([a-z0-9-]+)/i)?.[1]?.replace(/-/g, ' ') ?? null
        const district = districtFromUrl ?? inferDistrict(name)

        if (name || listingUrl) {
          listings.push({
            title: name || 'Apartment listing',
            sourceUrl: listingUrl || pageUrl,
            price,
            currency: currency ?? (price ? 'EUR' : null),
            sizeM2,
            bedrooms: rooms ? Math.round(rooms) : null,
            district,
            city: 'Novi Sad',
            imageUrl,
            floor: null,
            furnished: null,
          })
        }
      }
    } catch {
      // not valid JSON or wrong structure — skip
    }
  })

  if (listings.length > 0) return listings

  // ── Strategy 2: Anchor text extraction (fallback) ────────────
  const seenUrls = new Set<string>()
  $('a[href*="izdavanje-stanova"]').each((_, el) => {
    const href = $(el).attr('href') ?? ''
    if (!/\d{3,}/.test(href) || href.endsWith('/novi-sad')) return
    const absUrl = resolveUrl(href, pageUrl)
    if (!absUrl || seenUrls.has(absUrl)) return

    const parent = $(el).closest('div')
    const parentText = stripHtml(parent.text()).trim()
    const priceMatch = parentText.match(/(\d{2,4})\s*€/)
    if (!priceMatch) return

    seenUrls.add(absUrl)
    const text = stripHtml($(el).text()).trim()
    const district = inferDistrict(text) ?? inferDistrict(parentText)

    listings.push({
      title: text.split(/\d{2,4}\s*€/)[0]?.trim().substring(0, 120) || 'Apartment listing',
      sourceUrl: absUrl,
      price: Number(priceMatch[1]),
      currency: 'EUR',
      sizeM2: null,
      bedrooms: inferBedrooms(parentText),
      district,
      city: 'Novi Sad',
      imageUrl: null,
      floor: null,
      furnished: null,
    })
  })

  return listings
}

// ── Halo Oglasi Scraper ──────────────────────────────────────────

const buildHaloOglasiUrls = (config: LiveScraperConfig): string[] => {
  const cityParam = encodeURIComponent(config.city)
  const urls: string[] = []

  if (config.baseUrlOverride) {
    urls.push(config.baseUrlOverride)
  } else {
    urls.push(`https://www.halooglasi.com/nekretnine/izdavanje-stanova?location_l1=${cityParam}`)
  }

  for (let page = 2; page <= config.maxPages; page++) {
    const baseUrl = config.baseUrlOverride ?? `https://www.halooglasi.com/nekretnine/izdavanje-stanova?location_l1=${cityParam}`
    urls.push(`${baseUrl}&page=${page}`)
  }

  return urls
}

const parseHaloOglasiListings = (html: string, pageUrl: string): ScrapedListing[] => {
  const $ = cheerio.load(html)
  const listings: ScrapedListing[] = []

  // Halo Oglasi listing card selectors
  const cardSelectors = [
    '.product-item',
    '.listing-item',
    '.oglas-item',
    '[data-testid="listing"]',
    'article.listing',
    'div[class*="product"]',
    'div[class*="listing"]',
    'div[class*="oglas"]',
    '.search-results .item',
    '.results-list article',
    'article',
  ]

  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  let $cards: cheerio.Cheerio<any> = $([])
  for (const selector of cardSelectors) {
    $cards = $(selector)
    if ($cards.length > 0) break
  }

  if ($cards.length === 0) {
    // Fallback: extract from links
    const listingLinks = new Map<string, { title: string; context: string }>()
    $('a[href]').each((_, el) => {
      const href = $(el).attr('href') ?? ''
      const absUrl = resolveUrl(href, pageUrl)
      if (!absUrl || !absUrl.includes('halooglasi.com')) return
      if (!/\/(nekretnin|stan|izdavanje)/i.test(absUrl)) return
      if (!/\d{4,}/.test(absUrl)) return
      if (listingLinks.has(absUrl)) return

      const title = stripHtml($(el).text()).trim()
      const parent = $(el).closest('div, li, article')
      const context = stripHtml(parent.text()).trim().slice(0, 500)

      if (title.length >= 10 || context.length >= 20) {
        listingLinks.set(absUrl, { title: title || context.slice(0, 120), context })
      }
    })

    for (const [url, { title, context }] of listingLinks) {
      const price = extractPriceFromText(context)
      const size = extractSizeFromText(context)
      const bedrooms = inferBedrooms(context)
      const district = inferDistrict(context)

      listings.push({
        title,
        sourceUrl: url,
        price: price.value,
        currency: price.value ? 'EUR' : null,
        sizeM2: size,
        bedrooms,
        district,
        city: configCityFromUrl(pageUrl),
        imageUrl: null,
        floor: null,
        furnished: null,
      })
    }

    return listings
  }

  $cards.each((_, card) => {
    const $card = $(card)
    const text = stripHtml($card.text()).trim()

    const $link = $card.find('a[href]').first()
    const href = $link.attr('href') ?? ''
    const sourceUrl = resolveUrl(href, pageUrl) ?? pageUrl

    const titleEl = $card.find('h2, h3, h4, [class*="title"], [class*="name"], [class*="naziv"]').first()
    const title = stripHtml(titleEl.text()).trim() || text.split('\n')[0]?.trim().slice(0, 120) || 'Apartment listing'

    const priceText = $card.find('[class*="price"], [class*="cena"]').text()
    const price = extractPriceFromText(priceText || text)

    const sizeText = $card.find('[class*="size"], [class*="area"], [class*="kvadrat"], [class*="povrs"]').text()
    const size = extractSizeFromText(sizeText || text)

    const imgSrc = $card.find('img').first().attr('src') ?? $card.find('img').first().attr('data-src') ?? null
    const bedrooms = inferBedrooms(text)
    const district = inferDistrict(text)

    listings.push({
      title,
      sourceUrl,
      price: price.value,
      currency: price.value ? 'EUR' : null,
      sizeM2: size,
      bedrooms,
      district,
      city: configCityFromUrl(pageUrl),
      imageUrl: imgSrc ? resolveUrl(imgSrc, pageUrl) : null,
      floor: null,
      furnished: null,
    })
  })

  return listings
}

// ── Shared extraction helpers ─────────────────────────────────────

const resolveUrl = (href: string, baseUrl: string): string | null => {
  try {
    return new URL(href, baseUrl).toString()
  } catch {
    return null
  }
}

const configCityFromUrl = (url: string): string => {
  try {
    const parsed = new URL(url)
    const path = parsed.pathname.toLowerCase()
    if (path.includes('novi-sad') || path.includes('novi%20sad')) return 'Novi Sad'
    if (path.includes('beograd') || path.includes('belgrade')) return 'Beograd'
    if (path.includes('nis') || path.includes('niš')) return 'Niš'
    if (path.includes('subotica')) return 'Subotica'
    // Check query params
    const locationParam = parsed.searchParams.get('location_l1') ?? ''
    if (locationParam.toLowerCase().includes('novi')) return 'Novi Sad'
    if (locationParam.toLowerCase().includes('beograd')) return 'Beograd'
  } catch { /* ignore */ }
  return 'Novi Sad'
}

const extractPriceFromText = (text: string): { value: number | null; confidence: number } => {
  if (!text) return { value: null, confidence: 0 }

  const patterns = [
    /([0-9]{1,3}(?:[\.\,\s]?[0-9]{3})*)\s?(?:€|eur|evra)/i,
    /(?:€|eur)\s?([0-9]{1,3}(?:[\.\,\s]?[0-9]{3})*)/i,
    /([3-9][0-9]{2,4})\s?(?:€|eur|evra|mesečno|mesecno|monthly)\b/i,
  ]

  for (const pattern of patterns) {
    const match = text.match(pattern)
    if (match) {
      const cleaned = match[1].replace(/[\.\,\s]/g, '')
      const num = Number(cleaned)
      if (Number.isFinite(num) && num >= 50 && num <= 50000) {
        return { value: num, confidence: 0.9 }
      }
    }
  }

  return { value: null, confidence: 0 }
}

const extractSizeFromText = (text: string): number | null => {
  if (!text) return null
  const match = text.match(/([0-9]{2,4})\s?(?:m2|m²|kv\.?|sqm)/i)
  if (match) {
    const num = Number(match[1])
    if (Number.isFinite(num) && num >= 10 && num <= 1000) return num
  }
  return null
}

// ── Portal router ────────────────────────────────────────────────

const buildUrls = (config: LiveScraperConfig): string[] => {
  switch (config.portal) {
    case '4zida':
      return build4zidaUrls(config)
    case 'halooglasi':
      return buildHaloOglasiUrls(config)
    default:
      return build4zidaUrls(config)
  }
}

const parseListings = (portal: PortalKey, html: string, pageUrl: string): ScrapedListing[] => {
  switch (portal) {
    case '4zida':
      return parse4zidaListings(html, pageUrl)
    case 'halooglasi':
      return parseHaloOglasiListings(html, pageUrl)
    default:
      return parse4zidaListings(html, pageUrl)
  }
}

// ── Main connector ───────────────────────────────────────────────

export class LiveScraperConnector implements OpportunityConnector {
  name = 'LiveScraperConnector'
  type = 'live_scraper'

  async fetchOpportunities(input: ConnectorInput): Promise<RawOpportunity[]> {
    const config = parseConfig(input)
    const urls = buildUrls(config)
    const brief = input.brief

    const diagnostics: Record<string, unknown> = {
      connector: this.name,
      portal: config.portal,
      city: config.city,
      districts: config.districts,
      maxPages: config.maxPages,
      urls,
      pagesScraped: 0,
      totalListingsFound: 0,
      errors: [] as string[],
    }

    input.onTrace?.({
      stage: 'connector_execution',
      data: { ...diagnostics },
    })

    const allListings: ScrapedListing[] = []
    const errors: string[] = []

    for (const url of urls) {
      try {
        const html = await rateLimitedFetch(url)
        const listings = parseListings(config.portal, html, url)
        allListings.push(...listings)
        diagnostics.pagesScraped = Number(diagnostics.pagesScraped) + 1

        // Detect parser strategy used
        const hasJsonLd = html.includes('"ItemList"') || html.includes('"RealEstateListing"')
        const parserStrategy = hasJsonLd && listings.length > 0 ? 'json_ld' : 'anchor_text'
        const isJsRendered = html.includes('__NEXT_DATA__') || html.includes('__next_f')

        input.onTrace?.({
          stage: 'page_classified',
          data: {
            url,
            classification: 'search_results_page',
            cardsExtracted: listings.length,
            htmlLength: html.length,
            parserStrategy,
            isJsRendered,
          },
        })
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Unknown scrape error'
        errors.push(`${url}: ${message}`)

        input.onTrace?.({
          stage: 'error',
          data: { message: `Failed to scrape ${url}: ${message}` },
        })

        // If blocked (403/429), stop trying further pages
        if (/403|429|blocked|captcha/i.test(message)) {
          input.onTrace?.({
            stage: 'error',
            data: { message: `Blocked by ${config.portal}. Stopping further requests.` },
          })
          break
        }
      }
    }

    diagnostics.totalListingsFound = allListings.length
    diagnostics.errors = errors

    // Deduplicate by URL within this run
    const seen = new Set<string>()
    const uniqueListings = allListings.filter((listing) => {
      if (!listing.sourceUrl || seen.has(listing.sourceUrl)) return false
      seen.add(listing.sourceUrl)
      return true
    })

    // Convert to RawOpportunity
    const opportunities: RawOpportunity[] = uniqueListings.map((listing) => ({
      source_id: input.source.id,
      external_id: `live-${config.portal}-${listing.sourceUrl}`,
      source_url: listing.sourceUrl,
      title: listing.title || 'Apartment listing',
      description: null,
      country: brief.countries[0] ?? 'Serbia',
      city: listing.city ?? config.city,
      district: listing.district,
      price: listing.price,
      currency: listing.currency ?? brief.currency ?? 'EUR',
      size_m2: listing.sizeM2,
      bedrooms: listing.bedrooms,
      property_type: 'apartment',
      raw_payload: {
        origin: 'live_scraper',
        portal: config.portal,
        monthlyRent: listing.price,
        imageUrl: listing.imageUrl,
        floor: listing.floor,
        furnished: listing.furnished,
        module_type: 'rent',
        extraction_method: 'html_scrape',
        scraped_at: new Date().toISOString(),
        extraction_confidence: listing.price ? 0.85 : 0.5,
        needs_manual_completion: !listing.price || !listing.sizeM2,
      },
    }))

    input.onTrace?.({
      stage: 'listings_extracted',
      data: {
        ...diagnostics,
        uniqueListings: uniqueListings.length,
        rawOpportunitiesReturned: opportunities.length,
        status: errors.length > 0 && opportunities.length > 0
          ? 'partial'
          : errors.length > 0 && opportunities.length === 0
            ? 'parser_failed'
            : opportunities.length === 0
              ? 'no_results'
              : 'success',
      },
    })

    return opportunities
  }
}